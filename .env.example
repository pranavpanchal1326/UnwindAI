# .env.example — UnwindAI v4.0 — Updated for free LLM stack
# All 15 keys — commit this file, NEVER commit .env.local

# ─── FREE LLM PROVIDERS ──────────────────────────────────
# CHANGE-01: Replaces ANTHROPIC_API_KEY
# Get: aistudio.google.com — email only, no credit card
GOOGLE_AI_STUDIO_KEY=

# Get: console.groq.com — no credit card
GROQ_API_KEY=

# Get: cloud.cerebras.ai — no credit card
CEREBRAS_API_KEY=

# Get: openrouter.ai — optional fallback layer
OPENROUTER_API_KEY=

# Local Ollama — already in original doc
OLLAMA_BASE_URL=http://localhost:11434

# ─── SUPABASE ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ─── UPSTASH REDIS (BullMQ + Rate Limiting) ──────────────
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ─── WEB3 ─────────────────────────────────────────────────
POLYGON_RPC_URL=
WALLET_PRIVATE_KEY=
WEB3_STORAGE_TOKEN=
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# ─── NOTIFICATIONS ────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
RESEND_API_KEY=

# ─── APP ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEMO_MODE=false
# Set DEMO_MODE=true before demo — serves all cached responses
# Live demo costs ₹0 in API calls when DEMO_MODE=true
